# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PostgreSQL (Supabase → Settings → Database → Connection string)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
SHOP_NAME=ORIPA VAULT
CONTACT_EMAIL=oripakawa@gmail.com
ADMIN_EMAIL=oripakawa@gmail.com

# Gmail（Supabase Custom SMTP で使用 — 推奨）
GMAIL_USER=oripakawa@gmail.com
# [A] Gmail アプリパスワード（16文字・スペースなし）← ②Gmailパスワードを開く.bat
GMAIL_APP_PASSWORD=your-16-char-app-password
# [B] Supabase Token（sbp_ で始まる）← ①Tokenを開く.bat
# SUPABASE_ACCESS_TOKEN=sbp_...

# Email（optional — Resend）
RESEND_API_KEY=re_...
EMAIL_FROM=ORIPA VAULT <oripakawa@gmail.com>
# SEND_EMAIL_HOOK_SECRET=v1,whsec_...
